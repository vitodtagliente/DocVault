{
  "$schema": "https://schemas.tauri.app/config/v2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for DocVault",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-create-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-metadata",
    "fs:allow-copy-file",
    "notification:default",
    "notification:allow-send-notification",
    "shell:allow-open",
    "os:default",
    "http:default",
    "http:allow-fetch",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-reveal-item-in-file-manager",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}
